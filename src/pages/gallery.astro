---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGallery from '../components/PhotoGallery.tsx';
import { photos } from '../data/gallery';
---

<BaseLayout title="Gallery — Amaan Shaikh" description="Photography by Amaan Shaikh.">
  <h1 class="section-title">The <span>Gallery</span></h1>
  <p class="section-sub">A few edited frames — all shot on a phone. Click any photo to enlarge.</p>

  {/* Gallery + lightbox need click interactivity → hydrate when scrolled into view. */}
  <PhotoGallery client:visible photos={photos} />
</BaseLayout>
