---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
import { posts } from '../data/posts';
import { photos } from '../data/gallery';

const latestPost = posts[0];
// A small preview for the home page; full set lives on /gallery.
const featuredPhotos = [photos[0], photos[1], photos[2], photos[3]];

// Square, face/subject-aware thumbnail for the preview strip (cheaper than the full src).
const squareThumb = (src: string) =>
  src.replace(/\/upload\/[^/]+\//, '/upload/c_fill,g_auto,f_auto,q_auto,w_500,h_500/');

// Web3Forms access key (public by design). If unset, the contact section shows an email button.
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;

// Avatar served from Cloudinary (profile/ folder, kept out of the gallery list).
// c_fill,g_face = face-centered square crop; f_auto/q_auto = optimized delivery.
const cloud = 'https://res.cloudinary.com/dys9t7kn1/image/upload';
const avatar = `${cloud}/c_fill,g_face,f_auto,q_auto:best,w_400,h_400/profile/avatar.jpg`;
const avatar2x = `${cloud}/c_fill,g_face,f_auto,q_auto:best,w_800,h_800/profile/avatar.jpg`;
---

<BaseLayout title="Amaan Shaikh — Solution Consultant, Photographer">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__text">
      <h1>Hey, I'm <span class="accent">Amaan Shaikh</span></h1>
      <p class="hero__tag">Solution Consultant · Photographer · Occasional writer</p>
      <p class="hero__intro">
        I build software for a living at <strong>Sahaj</strong>, take photos on my phone
        whenever something catches my eye, and write when something's worth sharing.
      </p>
    </div>
    <img
      class="hero__avatar"
      src={avatar}
      srcset={`${avatar} 1x, ${avatar2x} 2x`}
      alt="Amaan Shaikh"
      width="180"
      height="180"
      loading="eager"
    />
  </section>

  <!-- About -->
  <section class="home-section">
    <div class="prose">
      <p>
        I'm from Dharmabad, a town in Nanded, Maharashtra, and studied Computer Science and
        Engineering at Walchand College of Engineering, Sangli. I first built this site during
        the lockdown to share my blogs and photographs — it's been rebuilt since, but the
        spirit is the same.
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section class="home-section">
    <div class="home-section__head">
      <h2 class="section-title">Things I've <span>built</span></h2>
      <a class="home-section__more" href="https://github.com/aweirdmaan" target="_blank" rel="noopener">
        All on GitHub &#8599;
      </a>
    </div>
    <div class="project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- Latest writing -->
  <section class="home-section">
    <div class="home-section__head">
      <h2 class="section-title">Latest <span>writing</span></h2>
      <a class="home-section__more" href="/blog">All posts &#8594;</a>
    </div>
    <div class="blog-list">
      <BlogCard post={latestPost} />
    </div>
  </section>

  <!-- Photography preview -->
  <section class="home-section">
    <div class="home-section__head">
      <h2 class="section-title">Through the <span>lens</span></h2>
      <a class="home-section__more" href="/gallery">Full gallery &#8594;</a>
    </div>
    <a class="photo-strip" href="/gallery" aria-label="Open the gallery">
      {
        featuredPhotos.map((photo) => (
          <span class="blurup" style={`background-image:url(${photo.lqip})`}>
            <img src={squareThumb(photo.src)} alt={photo.alt} loading="lazy" />
          </span>
        ))
      }
    </a>
  </section>

  <!-- Contact -->
  <section class="home-section" id="contact">
    <h2 class="section-title">Get in <span>touch</span></h2>
    <p class="section-sub">Have an idea, a question, or just want to say hi? Drop me a line.</p>

    {
      web3formsKey ? (
        <form class="contact" id="contact-form">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New message from aweirdmaan.pages.dev" />
          {/* Honeypot — bots fill this; humans never see it. */}
          <input type="checkbox" name="botcheck" class="contact__hp" tabindex="-1" autocomplete="off" />
          <div class="contact__row">
            <input type="text" name="name" placeholder="Your name" required />
            <input type="email" name="email" placeholder="Your email" required />
          </div>
          <textarea name="message" rows="4" placeholder="Your message" required />
          <div class="contact__actions">
            <button type="submit" class="btn">Send message</button>
            <p class="contact__status" aria-live="polite" />
          </div>
        </form>
      ) : (
        <a class="btn" href="mailto:amaanshaikh@gmail.com?subject=Hello%20Amaan">Email me</a>
      )
    }
  </section>

  {
    web3formsKey && (
      <script is:inline>
        {`
        document.addEventListener('astro:page-load', () => {
          const form = document.getElementById('contact-form');
          if (!form || form.dataset.bound) return;
          form.dataset.bound = '1';
          const status = form.querySelector('.contact__status');
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            status.textContent = 'Sending…';
            try {
              const res = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                body: JSON.stringify(Object.fromEntries(new FormData(form))),
              });
              const data = await res.json();
              if (data.success) { form.reset(); status.textContent = "✓ Thanks — I'll get back to you soon."; }
              else { status.textContent = 'Hmm, that failed. Try emailing me instead.'; }
            } catch { status.textContent = 'Network error. Try emailing me instead.'; }
          });
        });
        `}
      </script>
    )
  }
</BaseLayout>
